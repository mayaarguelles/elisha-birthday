---
import ProtectedLayout from '@layouts/ProtectedLayout.astro';

const password = import.meta.env.PASSWORD;
const steamCode1 = import.meta.env.STEAM_CODE_1;
const steamCode2 = import.meta.env.STEAM_CODE_2;
const leagueLink = import.meta.env.LEAGUE_LINK;
const bonusGift = import.meta.env.BONUS_GIFT;

const buttonClass = 'border block border-black rounded-[50%] px-20 py-2 hover:bg-black hover:text-white cursor-pointer w-full max-w-72';
const tooltipClass = 'copy-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 transition-opacity duration-300 text-xs bg-black text-white px-3 py-1.5 pointer-events-none text-center whitespace-nowrap';
---
<ProtectedLayout password={password}>
	<div class="min-h-screen w-full flex flex-col items-center justify-center">
		<img class="w-full h-auto xs:max-w-72 barbra-pic mb-4 aspect-square sm:aspect-auto object-cover" src="barbra.webp" alt="Barbra Streisand" />
		<div class="flex-[1_0_auto] xs:flex-[0_0_auto] text-center">
			<p class="text-center leading-tight">
				happy birthday elisha<br>
				we've been friends for a few years now<br>
				so here are some gifts
			</p>
			<ul class="mt-8 space-y-8">
				<li class="relative flex items-center justify-center">
					<span class={tooltipClass}>
						<span class="copy-code block font-mono"></span>
						<span class="block">copied to clipboard!</span>
					</span>
					<button class={buttonClass} data-copy={steamCode1}>steam code 1</button>
				</li>
				<li class="relative flex items-center justify-center">
					<span class={tooltipClass}>
						<span class="copy-code block font-mono"></span>
						<span class="block">copied to clipboard!</span>
					</span>
					<button class={buttonClass} data-copy={steamCode2}>steam code 2</button>
				</li>
				<li><a href={leagueLink} target="_blank" class={buttonClass}>league of legends</a></li>
				<li><a href={bonusGift} target="_blank" class={buttonClass}>bonus gift</a></li>
			</ul>
			<p class="mt-8">love, <br>
the real housewives of gippsland</p>
		</div>
	</div>
</ProtectedLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('button[data-copy]').forEach(btn => {
    let hideTimer: ReturnType<typeof setTimeout> | null = null;

    btn.addEventListener('click', () => {
      const code = btn.dataset.copy;
      if (!code) return;

      navigator.clipboard.writeText(code);

      const tooltip = btn.closest('li')?.querySelector<HTMLElement>('.copy-tooltip');
      const codeEl = tooltip?.querySelector<HTMLElement>('.copy-code');
      if (!tooltip || !codeEl) return;

      codeEl.textContent = code;
      tooltip.classList.remove('opacity-0');

      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        tooltip.classList.add('opacity-0');
      }, 2000);
    });
  });
</script>
